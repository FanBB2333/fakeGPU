#!/usr/bin/env bash
# Run a command with FakeGPU libraries preloaded.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BUILD_DIR="${FAKEGPU_BUILD_DIR:-${SCRIPT_DIR}/build}"

if [[ $# -eq 0 ]]; then
  echo "Usage: $(basename "$0") <command> [args...]" >&2
  exit 1
fi

if [[ ! -d "$BUILD_DIR" ]]; then
  echo "Build directory not found: $BUILD_DIR" >&2
  echo "Build FakeGPU first (e.g., cmake -S . -B build && cmake --build build)." >&2
  exit 1
fi

REQUIRED_LIBS=(
  "libcublas.so.12"
  "libcudart.so.12"
  "libcuda.so.1"
  "libnvidia-ml.so.1"
)

for lib in "${REQUIRED_LIBS[@]}"; do
  if [[ ! -f "${BUILD_DIR}/${lib}" ]]; then
    echo "Missing ${BUILD_DIR}/${lib}. Build the project before running this wrapper." >&2
    exit 1
  fi
done

export LD_LIBRARY_PATH="${BUILD_DIR}${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
export LD_PRELOAD="${BUILD_DIR}/libcublas.so.12:${BUILD_DIR}/libcudart.so.12:${BUILD_DIR}/libcuda.so.1:${BUILD_DIR}/libnvidia-ml.so.1${LD_PRELOAD:+:${LD_PRELOAD}}"

exec "$@"
